{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "paths": {
            "@drms/shared": [
                "../../packages/shared/src/index.ts"
            ],
            "@drms/database": [
                "../../packages/database/generated/client"
            ]
        }
    },
    "exclude": [
        "node_modules"
    ]
}